import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation

# -------------------------
# SERPENTINE GEOMETRY
# -------------------------
t_vals = np.linspace(0, 5*np.pi, N)  # 2.5 turns

x = t_vals
y = np.sin(t_vals)

# curvature-based weighting
curvature = np.abs(np.gradient(np.gradient(y)))

# -------------------------
# SIGNAL INIT
# -------------------------
signal = np.exp(-((x-2)**2))  # localized input

# -------------------------
# PROPAGATION
# -------------------------
frames = []

for step_i in range(100):
    new_signal = signal.copy()
    for i in range(1, N-1):
        lam = lambda_map[types[i]]
        new_signal[i] = (
            0.4*signal[i] +
            0.3*signal[i-1] +
            0.3*signal[i+1]
        ) * lam / (1 + curvature[i])
    signal = new_signal
    frames.append(signal.copy())

# -------------------------
# ANIMATION
# -------------------------
fig, ax = plt.subplots()

def update(frame):
    ax.clear()
    ax.scatter(x, y, c=frames[frame], cmap='viridis')
    ax.set_title(f"Step {frame}")

ani = FuncAnimation(fig, update, frames=100)
ani.save("serpentine_propagation.gif", fps=10)
